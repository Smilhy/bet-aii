# Frontend Vite / Supabase (wartości publiczne)
VITE_SUPABASE_URL=https://TWOJ-PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=TWOJ_SUPABASE_ANON_KEY

# Netlify Functions / Supabase (sekret — ustaw wyłącznie w Netlify Environment variables)
SUPABASE_URL=https://TWOJ-PROJEKT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TWOJ_SUPABASE_SERVICE_ROLE_KEY
# Starsze funkcje w paczce obsługują również tę nazwę:
SUPABASE_SERVICE_KEY=TWOJ_SUPABASE_SERVICE_ROLE_KEY

# Adres wdrożonej strony
PUBLIC_SITE_URL=https://twoja-domena.netlify.app
# Opcjonalne zakresy kursów automatów AI — WERSJA 1867.3
BETAI_VALUE_V2_MIN_ODDS=1.50
BETAI_VALUE_V2_MAX_ODDS=5.00
TYPER_EXPERT_MIN_ODDS=1.50
TYPER_EXPERT_MAX_ODDS=5.00
OGRAC_BUKA_MIN_ODDS=1.50
OGRAC_BUKA_MAX_ODDS=5.00


# WERSJA 1880 — Algorytm Over/Under 2.5
# Ten sam klucz API-Football, którego używają pozostałe funkcje.
APISPORTS_KEY=TWOJ_API_FOOTBALL_KEY
# Liczba wcześniejszych meczów do średnich strzałów/rożnych (3-10).
ALGORITHM_FORM_MATCHES=5
# Maksymalna liczba nowych spotkań analizowanych w jednym skanie.
ALGORITHM_MAX_FIXTURES=12
# Minimalne EV w zapisie dziesiętnym: 0 = co najmniej 0%, 0.03 = co najmniej 3%.
ALGORITHM_MIN_EDGE=0
# E-maile administratorów mogących ręcznie uruchomić skan z dashboardu.
ALGORITHM_ADMIN_EMAILS=smilhytv@gmail.com

# WERSJA 1886 — bezpieczny automat PRE-MATCH
# Jedno zapytanie API mniej więcej co 350 ms (ok. 2,8/s; plan Pro ma limit 5/s).
ALGORITHM_API_MIN_INTERVAL_MS=350
# Po limicie minutowym odczekaj 65 sekund i spróbuj ponownie.
ALGORITHM_API_RATE_LIMIT_RETRY_MS=65000
ALGORITHM_API_MAX_RATE_RETRIES=2
# Nie rozpoczynaj analizy meczu później niż 10 minut przed kickoffem.
ALGORITHM_PREMATCH_MIN_LEAD_MINUTES=10
# Ile meczów kolejki worker może przetworzyć w jednym cyklu.
ALGORITHM_PROCESS_BATCH=20
# Maksymalna liczba historycznych spotkań sprawdzanych dla jednej drużyny.
ALGORITHM_MAX_HISTORY_STATS_CHECKS=8
# Po ilu pełnych próbach bez danych oznaczyć mecz jako „Brak statystyk”.
ALGORITHM_MAX_MISSING_DATA_ATTEMPTS=2
